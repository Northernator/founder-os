{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noConfusingVoidType": "off",
        "noImplicitAnyLet": "warn",
        "noAssignInExpressions": "warn",
        "noAsyncPromiseExecutor": "warn",
        "noConsoleLog": "off",
        "noConsole": "off",
        "noArrayIndexKey": "warn",
        "noControlCharactersInRegex": "off"
      },
      "style": {
        "useImportType": "error",
        "useConsistentArrayType": "warn",
        "noNonNullAssertion": "warn",
        "useTemplate": "warn",
        "noUnusedTemplateLiteral": "warn",
        "noParameterAssign": "warn",
        "noUselessElse": "warn",
        "useNumberNamespace": "warn",
        "useNodejsImportProtocol": "warn",
        "useExponentiationOperator": "warn",
        "useSelfClosingElements": "warn"
      },
      "complexity": {
        "noForEach": "warn",
        "useArrowFunction": "warn",
        "useOptionalChain": "warn",
        "useLiteralKeys": "warn",
        "noUselessConstructor": "warn",
        "noBannedTypes": "warn",
        "noStaticOnlyClass": "warn"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn",
        "useExhaustiveDependencies": "warn"
      },
      "a11y": {
        "useKeyWithClickEvents": "off",
        "useButtonType": "warn",
        "useAltText": "warn",
        "useSemanticElements": "warn",
        "noSvgWithoutTitle": "off",
        "useValidAnchor": "warn",
        "noLabelWithoutControl": "off",
        "noAutofocus": "off",
        "noNoninteractiveTabindex": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "off",
        "noDangerouslySetInnerHtmlWithChildren": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "**/node_modules/**",
      "dist",
      "**/dist/**",
      "build",
      "**/build/**",
      "out",
      "**/out/**",
      ".turbo",
      "**/.turbo/**",
      "tmp",
      "**/tmp/**",
      "**/pnpm-vstore/**",
      "**/.bin/**",
      "apps/founder-desktop/src-tauri/target",
      "apps/founder-desktop/src-tauri/gen",
      "ventures/**/.founder",
      "*.tsbuildinfo",
      "**/*.tsbuildinfo",
      "pnpm-lock.yaml"
    ]
  },
  "overrides": [
    {
      "include": ["apps/founder-desktop/src/**"],
      "linter": {
        "rules": {
          "nursery": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "node:fs": "Tauri WebView cannot run Node modules -- use Tauri commands (invoke) for filesystem access.",
                  "node:fs/promises": "Tauri WebView cannot run Node modules -- use Tauri commands (invoke) for filesystem access.",
                  "node:path": "Tauri WebView cannot run Node modules -- use @tauri-apps/api/path.",
                  "node:os": "Tauri WebView cannot run Node modules -- use @tauri-apps/api/os.",
                  "node:crypto": "Tauri WebView cannot run Node modules -- use globalThis.crypto.subtle.",
                  "node:child_process": "Tauri WebView cannot spawn processes -- use Tauri commands.",
                  "node:stream": "Tauri WebView cannot run Node modules -- use Web Streams.",
                  "node:util": "Tauri WebView cannot run Node modules.",
                  "node:events": "Tauri WebView cannot run Node modules -- use EventTarget.",
                  "node:buffer": "Tauri WebView cannot run Node modules -- use Uint8Array.",
                  "@founder-os/prompt-master/node": "The /node entry point pulls in Node-only deps. Desktop app uses the client-safe barrel: import from @founder-os/prompt-master only."
                }
              }
            }
          }
        }
      }
    }
  ]
}
