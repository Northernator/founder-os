{
  "name": "founder-os",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules",
    "desktop:dev": "pnpm --filter founder-desktop dev",
    "desktop:build": "pnpm --filter founder-desktop build",
    "desktop:tauri": "pnpm --filter founder-desktop tauri dev",
    "extension:build": "pnpm --filter founder-cowork build",
    "extension:package": "pnpm --filter founder-cowork package",
    "seed": "pnpm --filter founder-desktop seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  }
}
