# Copy to .env and edit. .env is gitignored.
# All values optional - defaults work for fully-local dev with the
# exception of the LLM keys, which are required for /research/deep.

# Optional: gate the local Firecrawl API behind a shared secret.
# If unset, the API is open (USE_DB_AUTHENTICATION=false in compose).
FIRECRAWL_API_KEY=

# Optional: a long random string SearXNG uses to sign sessions.
# Generated on first run if you leave it empty in settings.yml.
SEARXNG_SECRET=

# If `docker compose pull` returns 401 from ghcr.io, set a GitHub PAT
# with read:packages scope and run:
#   echo $GHCR_PAT | docker login ghcr.io -u <github-username> --password-stdin
GHCR_PAT=

# ----------------------------------------------------------------------
# Phase 2b - GPT-Researcher (deep research) configuration
# ----------------------------------------------------------------------
# Which LLM provider to use as the default for research jobs.
# Options: openai | anthropic | ollama
LLM_PROVIDER=openai

# Provider credentials. Set the one matching LLM_PROVIDER above.
# Leave the others blank.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama base URL. Default points at the host's Ollama daemon via
# host.docker.internal (works on Docker Desktop for Windows/Mac and
# is wired up via extra_hosts on Linux too).
# Leave blank to keep the default.
OLLAMA_BASE_URL=

# ----------------------------------------------------------------------
# Optional per-slot model overrides. Leave blank to use the
# provider-default models defined in research_py/config.py:
#
#   openai     fast=openai:gpt-4o-mini       smart=openai:gpt-4o
#              strategic=openai:gpt-4o       embedding=openai:text-embedding-3-small
#   anthropic  fast=anthropic:claude-3-5-haiku-latest
#              smart=anthropic:claude-sonnet-4-6
#              strategic=anthropic:claude-opus-4-6
#              embedding=openai:text-embedding-3-small  (needs OPENAI_API_KEY too)
#   ollama     fast=ollama:llama3.2          smart=ollama:llama3.1:70b
#              strategic=ollama:llama3.1:70b embedding=ollama:nomic-embed-text
#
# Format is "<provider>:<model>".
FAST_LLM=
SMART_LLM=
STRATEGIC_LLM=
EMBEDDING=
